{
  "name": "@vxlx/surrealdb-better-auth",
  "version": "0.9.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vxlx-platform/surrealdb-better-auth.git"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "devDependencies": {
    "@better-auth/core": "^1.6.2",
    "@better-auth/passkey": "^1.6.2",
    "@better-auth/utils": "^0.4.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "@vitest/browser-playwright": "^4.0.18",
    "better-auth": "^1.6.2",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "oxlint-tsgolint": "^0.16.0",
    "playwright": "^1.57.0",
    "surrealdb": "^2.0.2",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@better-auth/core": "^1.5.4",
    "@better-auth/utils": "^0.3.1",
    "surrealdb": "^2.0.2"
  },
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "bugs": {
    "url": "https://github.com/vxlx-platform/surrealdb-better-auth/issues"
  },
  "description": "SurrealDB adapter for Better Auth",
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/vxlx-platform/surrealdb-better-auth#readme",
  "keywords": [
    "auth",
    "surrealdb",
    "adapter",
    "typescript",
    "better-auth"
  ],
  "license": "MIT",
  "peerDependenciesMeta": {
    "surrealdb": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "dev:server": "bun run ./examples/bun-server.ts",
    "lint": "oxlint src tests vitest.config.ts",
    "lint:fix": "oxlint --fix src tests vitest.config.ts",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm run test:unit",
    "test": "vitest run --config vitest.config.ts",
    "test:all": "vitest run --config vitest.config.ts",
    "test:mock": "vitest run --config vitest.config.ts tests/unit",
    "test:unit": "vitest run --config vitest.config.ts tests/unit",
    "test:integration": "vitest run --config vitest.config.ts tests/integration",
    "typecheck:src": "tsc --noEmit -p tsconfig.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "typecheck": "bun run typecheck:src && bun run typecheck:tests"
  },
  "type": "module",
  "types": "./dist/index.d.mts"
}