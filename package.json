{
  "name": "@vxlx/surrealdb-better-auth",
  "version": "0.2.0",
  "description": "SurrealDB adapter for Better Auth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vxlx-platform/surrealdb-better-auth.git"
  },
  "homepage": "https://github.com/vxlx-platform/surrealdb-better-auth#readme",
  "bugs": {
    "url": "https://github.com/vxlx-platform/surrealdb-better-auth/issues"
  },
  "bin": {
    "surrealdb-better-auth": "./dist/cli.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "oxlint src tests vitest.config.ts",
    "lint:fix": "oxlint --fix src tests vitest.config.ts",
    "migration": "bun run ./src/cli.ts migrate",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm run test:unit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "peerDependencies": {
    "better-auth": "^1.5.4",
    "surrealdb": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "better-auth": "^1.5.4",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "oxlint-tsgolint": "^0.16.0",
    "surrealdb": "^2.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
