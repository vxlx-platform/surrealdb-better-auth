{
  "name": "@vxlx/surrealdb-better-auth",
  "version": "0.5.1",
  "description": "SurrealDB adapter for Better Auth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vxlx-platform/surrealdb-better-auth.git"
  },
  "homepage": "https://github.com/vxlx-platform/surrealdb-better-auth#readme",
  "bugs": {
    "url": "https://github.com/vxlx-platform/surrealdb-better-auth/issues"
  },
  "bin": {
    "surrealdb-better-auth": "./dist/cli.mjs"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./schema": {
      "dev-source": "./src/schema.ts",
      "types": "./dist/schema.d.mts",
      "default": "./dist/schema.mjs"
    },
    "./cli": {
      "dev-source": "./src/cli.ts",
      "default": "./dist/cli.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "dev:server": "bun run ./examples/bun-server.ts",
    "lint": "oxlint src tests vitest.config.ts",
    "lint:fix": "oxlint --fix src tests vitest.config.ts",
    "migration": "bun run ./src/cli.ts migrate",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm run test:unit",
    "test": "vitest run",
    "test:browser:setup": "playwright install chromium",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "better-auth": "^1.5.4",
    "surrealdb": "^2.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "@vitest/browser-playwright": "^4.0.18",
    "better-auth": "^1.5.4",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "oxlint-tsgolint": "^0.16.0",
    "playwright": "^1.57.0",
    "surrealdb": "^2.0.2",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
