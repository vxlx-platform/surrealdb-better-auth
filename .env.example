# Example Bun server
PORT=3333
SURREALDB_ENDPOINT=ws://localhost:8000/rpc
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root
SURREALDB_NAMESPACE=main
SURREALDB_DATABASE=main
BETTER_AUTH_BASE_URL=http://127.0.0.1:3333
JWT_ALG=RS256
JWT_JWKS_PATH=/.well-known

# Optional: shape Better Auth JWTs for SurrealDB record access
# Must match DEFINE ACCESS <name> ... TYPE RECORD WITH JWT
SURREALDB_ACCESS=

# Integration tests
SURREALDB_TEST_ENDPOINT=ws://localhost:8000/rpc
SURREALDB_TEST_USERNAME=root
SURREALDB_TEST_PASSWORD=root
SURREALDB_TEST_NAMESPACE=main
SURREALDB_TEST_DATABASE=main

# Set to 1 to isolate test namespaces/databases by worker id
SURREALDB_TEST_ISOLATE=0
